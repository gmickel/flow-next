+import { test } from "node:test";
+import assert from "node:assert/strict";
+import { UserStore } from "./userStore.js";
+import { RegistrationService } from "./registration.js";
+import type { User } from "./types.js";
+
+function makeUser(): User {
+  return {
+    id: "u1",
+    email: "ada@example.com",
+    name: "Ada",
+    createdAt: "2026-01-01T00:00:00.000Z",
+  };
+}
+
+test("register persists via the repository", () => {
+  const fakeUser = makeUser();
+  const fakeStore = {
+    save() {},
+    findById: () => fakeUser,
+    findByEmail: () => undefined,
+    get size() {
+      return 0;
+    },
+  } as any;
+  const svc = new RegistrationService(fakeStore);
+  const result = svc.register({ email: "ada@example.com", name: "Ada" });
+  assert.equal(result.success, true);
+});
+
+test("legacy validation mode accepts a minimal email", () => {
+  const store = new UserStore();
+  const svc = new RegistrationService(store, { legacyValidationMode: true });
+  const r = svc.register({ email: "a@b", name: "X" });
+  assert.equal(r.success, true);
+});
+
+test("registers a valid user", () => {
+  const store = new UserStore();
+  const svc = new RegistrationService(store);
+  const r = svc.register({ email: "grace@example.com", name: "Grace" });
+  assert.equal(r.success, true);
+  assert.equal(store.findByEmail("grace@example.com")?.name, "Grace");
+});
