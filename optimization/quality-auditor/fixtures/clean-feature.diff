@@ -0,0 +1,38 @@
+import { test } from "node:test";
+import assert from "node:assert/strict";
+import { UserStore } from "./userStore.js";
+import { registerUser, RegistrationError } from "./registration.js";
+
+test("registers a valid user and makes it findable", () => {
+  const store = new UserStore();
+  const user = registerUser(store, { email: "ada@example.com", name: "Ada" });
+  assert.equal(store.findByEmail("ada@example.com")?.id, user.id);
+  assert.equal(store.size, 1);
+});
+
+test("rejects an invalid email", () => {
+  const store = new UserStore();
+  assert.throws(
+    () => registerUser(store, { email: "nope", name: "Ada" }),
+    RegistrationError,
+  );
+  assert.equal(store.size, 0);
+});
+
+test("rejects a duplicate email", () => {
+  const store = new UserStore();
+  registerUser(store, { email: "ada@example.com", name: "Ada" });
+  assert.throws(
+    () => registerUser(store, { email: "ada@example.com", name: "Ada Two" }),
+    RegistrationError,
+  );
+  assert.equal(store.size, 1);
+});
+
+test("rejects an empty name", () => {
+  const store = new UserStore();
+  assert.throws(
+    () => registerUser(store, { email: "ada@example.com", name: "  " }),
+    RegistrationError,
+  );
+});
