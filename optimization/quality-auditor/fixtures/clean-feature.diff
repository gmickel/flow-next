@@ -0,0 +1,42 @@
+import { randomUUID } from "node:crypto";
+import type { User } from "./types.js";
+import { UserStore } from "./userStore.js";
+import { validateEmail } from "./email.js";
+
+export interface RegistrationInput {
+  email: string;
+  name: string;
+}
+
+export class RegistrationError extends Error {}
+
+/**
+ * Register a new user into `store`.
+ *
+ * Validates the untrusted input (a real trust boundary — this is where
+ * caller-supplied data enters the service), rejects duplicate emails, and
+ * returns the stored user.
+ */
+export function registerUser(store: UserStore, input: RegistrationInput): User {
+  const email = input.email.trim();
+  const name = input.name.trim();
+
+  if (!validateEmail(email)) {
+    throw new RegistrationError(`invalid email: ${input.email}`);
+  }
+  if (name.length === 0) {
+    throw new RegistrationError("name must not be empty");
+  }
+  if (store.findByEmail(email) !== undefined) {
+    throw new RegistrationError(`email already registered: ${email}`);
+  }
+
+  const user: User = {
+    id: randomUUID(),
+    email,
+    name,
+    createdAt: new Date().toISOString(),
+  };
+  store.save(user);
+  return user;
+}
